# ============================================================================
# OffX environment variables
# Copy to .env.local and fill in. NEVER commit .env.local.
# ============================================================================

# Where the app is deployed. Used to build OAuth redirect URIs + absolute URLs.
# Dev:  http://localhost:3000
# Prod: https://offlinex.org
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ----- Session -------------------------------------------------------------
# 32 random bytes as a URL-safe string. Generate with:
#   openssl rand -base64 32
SESSION_SECRET=

# ----- X (Twitter) API ------------------------------------------------------
# Create a project + app at https://developer.x.com
# App type: Web App, Confidential client
# Redirect URI: ${NEXT_PUBLIC_APP_URL}/api/auth/x/callback
# Scopes: tweet.read tweet.write users.read offline.access
X_CLIENT_ID=
X_CLIENT_SECRET=

# ----- Twilio --------------------------------------------------------------
# Account at https://twilio.com
# Buy a long-code phone number (SMS enabled) and enable Messaging
# Geo-Permissions for every country you want to serve:
#   https://console.twilio.com/us1/develop/sms/settings/geo-permissions
# Configure the inbound SMS webhook on your number to:
#   ${NEXT_PUBLIC_APP_URL}/api/sms/inbound   (HTTP POST)
# Phone OTPs are issued locally and sent via Messages (see src/lib/otp.ts),
# so no Verify service SID is required.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+14155550108

# ----- Supabase -------------------------------------------------------------
# Create a project at https://supabase.com
# Run the migration: supabase/migrations/0001_init.sql
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
